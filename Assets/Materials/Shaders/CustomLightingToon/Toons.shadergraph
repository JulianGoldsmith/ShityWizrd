{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "d86773d4c6fa4940ac33b265bc2ff27f",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "PerLightToon (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -171.99996948242188,
            "y": 45.60000991821289,
            "width": 230.39996337890626,
            "height": 165.60000610351563
        }
    },
    "m_Slots": [
        {
            "m_Id": "f39c55ea332f45cc8f0df5a5e2dae34c"
        },
        {
            "m_Id": "48988f1a2e7c490d8c4d09811943498d"
        },
        {
            "m_Id": "f1e265bfebfe490598acd385dbbc541d"
        },
        {
            "m_Id": "788095989c1b44dc88f784975116e599"
        },
        {
            "m_Id": "7808b91f6ab3445a9ca0540487de632c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "PerLightToon",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "OutColor = float3(0, 0, 0);\n\n#ifndef SHADERGRAPH_PREVIEW\n    // 1. CALCULATE THE SUN (Main Light)\n    #if defined(UNIVERSAL_PIPELINE_CORE_INCLUDED)\n        float4 shadowCoord = TransformWorldToShadowCoord(WorldPosition);\n        Light mainLight = GetMainLight(shadowCoord);\n    #else\n        Light mainLight = GetMainLight();\n    #endif\n\n    float mainNdotL = saturate(dot(WorldNormal, mainLight.direction));\n    float mainAtten = mainLight.shadowAttenuation;\n    \n    // --> STEP THE SUN <--\n    float mainBanded = floor((mainNdotL * mainAtten) * Bands) / Bands;\n    OutColor += mainLight.color * mainBanded * BaseColor;\n\n\n    // 2. CALCULATE POINT LIGHTS & SPELLS (Additional Lights)\n    #if defined(_ADDITIONAL_LIGHTS) || defined(_CLUSTER_LIGHT_LOOP)\n        uint lightCount = GetAdditionalLightsCount();\n        for(uint i = 0; i < lightCount; ++i) \n        {\n            Light light = GetAdditionalLight(i, WorldPosition);\n            float NdotL = saturate(dot(WorldNormal, light.direction));\n            float atten = light.distanceAttenuation * light.shadowAttenuation;\n            \n            // --> STEP EACH POINT LIGHT INDIVIDUALLY <--\n            float banded = floor((NdotL * atten) * Bands) / Bands;\n            \n            OutColor += light.color * banded * BaseColor;\n        }\n    #endif\n\n#else\n    // 3. SHADER GRAPH PREVIEW WINDOW PLACEHOLDER\n    float previewNdotL = saturate(dot(WorldNormal, float3(0.5, 0.7, 0)));\n    float previewBanded = floor(previewNdotL * Bands) / Bands;\n    OutColor = BaseColor * previewBanded;\n#endif"
}

