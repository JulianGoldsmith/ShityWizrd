    \"m_FunctionSource\": \"\",\n    \"m_FunctionSourceUsePragmas\": true,\n    \"m_FunctionBody\":
    \"#if !defined(SHADERGRAPH_PREVIEW) && defined(_DBUFFER)\\n\\tApplyDecal(positionCS,
